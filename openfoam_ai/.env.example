# OpenFOAM AI Agent 环境变量配置
# 复制此文件为 .env 并填写您的配置

# OpenAI API配置
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4

# 可选: 其他LLM提供商
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=

# 运行配置
DEFAULT_CASES_PATH=./cases
LOG_LEVEL=INFO

# 调试选项
DEBUG=false
MOCK_MODE=false

# 执行选项
AUTO_FIX_ENABLED=true
REQUIRE_CONFIRMATION=true
MAX_AUTO_RETRY=3

# ============================================================
# 多模型智能路由配置
# ============================================================
# 是否启用多模型路由（true/false）
ENABLE_LLM_ROUTING=true

# 路由模式: balanced（平衡）/ low_cost（低成本）/ high_quality（高质量）
LLM_ROUTING_MODE=balanced

# 各任务类型的指定提供商（可选，设置后覆盖 YAML 配置）
# 可选值: openai, kimi, deepseek, doubao, glm, minimax, aliyun
LLM_PROVIDER_CONFIG_GEN=deepseek
LLM_PROVIDER_EXPLAIN=kimi
LLM_PROVIDER_REVIEW=deepseek
LLM_PROVIDER_INTENT=aliyun
LLM_PROVIDER_LOG_ANALYSIS=deepseek
