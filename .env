# OpenFOAM AI Agent - 环境变量配置示例
# 复制此文件为 .env 并填入您的 API Key

# 选择默认 LLM 提供商
# 可选: openai, kimi, deepseek, doubao, glm, minimax, aliyun
DEFAULT_LLM_PROVIDER=kimi

# OpenAI (GPT-3.5/GPT-4)
OPENAI_API_KEY=sk-your-openai-key-here

# KIMI (Moonshot AI) - 推荐，中文支持好
KIMI_API_KEY=sk-CiZKfsbs7nCT9Sw5BmYXjv9cUnFcjAOtQicG2kYsKJWOnCuL

# DeepSeek
DEEPSEEK_API_KEY=sk-8255449785ae42f489ebf47222e2fc03

# 豆包 (ByteDance) - 通过阿里云百炼
DOUBAO_API_KEY=sk-83a8354476444612a35756b69968d3bb

# GLM (Zhipu AI)
GLM_API_KEY=your-glm-key-here

# MiniMax
MINIMAX_API_KEY=your-minimax-key-here

# 阿里云百炼
ALIYUN_API_KEY=sk-83a8354476444612a35756b69968d3bb

# ============================================================
# 多模型智能路由配置
# ============================================================
# 是否启用多模型路由（true/false）
ENABLE_LLM_ROUTING=true

# 路由模式: balanced（平衡）/ low_cost（低成本）/ high_quality（高质量）
LLM_ROUTING_MODE=balanced

# 各任务类型的指定提供商（可选，设置后覆盖 YAML 配置）
# 可选值: openai, kimi, deepseek, doubao, glm, minimax, aliyun
LLM_PROVIDER_CONFIG_GEN=deepseek
LLM_PROVIDER_EXPLAIN=kimi
LLM_PROVIDER_REVIEW=deepseek
LLM_PROVIDER_INTENT=aliyun
LLM_PROVIDER_LOG_ANALYSIS=deepseek
